{
  "name": "shows",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "scraper:broadway": "ts-node --project scrapers/tsconfig.json scrapers/venues/the-broadway.ts",
    "scraper:tv-eye": "ts-node --project scrapers/tsconfig.json scrapers/venues/tv-eye.ts",
    "scraper:monarch": "ts-node --project scrapers/tsconfig.json scrapers/venues/brooklyn-monarch.ts",
    "scraper:market-hotel": "ts-node --project scrapers/tsconfig.json scrapers/venues/market-hotel.ts",
    "scraper:wonderville": "ts-node --project scrapers/tsconfig.json scrapers/venues/wonderville.ts",
    "test:broadway": "ts-node --project scrapers/tsconfig.json scrapers/test-broadway.ts",
    "test:tv-eye": "ts-node --project scrapers/tsconfig.json scrapers/test-tv-eye.ts",
    "db:clear": "ts-node --project scrapers/tsconfig.json scripts/db-clear.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^1.1.1",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "next": "^16.2.4",
    "prisma": "^7.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "25.6.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.59.1",
    "ts-node": "^10.9.2"
  }
}
